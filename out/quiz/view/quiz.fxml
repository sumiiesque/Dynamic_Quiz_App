<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!-- Quiz Screen: Question + Options + Timer + Progress -->
<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="quiz.controller.QuizController"
           styleClass="root-pane"
           prefWidth="900" prefHeight="650">

    <VBox alignment="TOP_CENTER" spacing="20"
          styleClass="card" maxWidth="700">

        <padding>
            <Insets top="35" right="40" bottom="35" left="40"/>
        </padding>

        <!-- Header: Question counter + Timer -->
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label fx:id="questionCounter" text="Q1 / 10"
                   styleClass="counter-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="8" styleClass="timer-box">
                <Label text="Time:" styleClass="timer-text"/>
                <Label fx:id="timerLabel" text="60" styleClass="timer-label"/>
                <Label text="s" styleClass="timer-text"/>
            </HBox>
        </HBox>

        <!-- Progress Bar -->
        <ProgressBar fx:id="progressBar" progress="0.0"
                     prefHeight="8" maxWidth="Infinity"
                     styleClass="quiz-progress"/>

        <!-- Question text -->
        <Label fx:id="questionText" text=""
               styleClass="question-label" wrapText="true"
               maxWidth="600"/>

        <!-- 4 Radio-button options (ToggleGroup is set in controller) -->
        <VBox spacing="14" styleClass="options-container">
            <RadioButton fx:id="optA" styleClass="option-radio" maxWidth="Infinity"/>
            <RadioButton fx:id="optB" styleClass="option-radio" maxWidth="Infinity"/>
            <RadioButton fx:id="optC" styleClass="option-radio" maxWidth="Infinity"/>
            <RadioButton fx:id="optD" styleClass="option-radio" maxWidth="Infinity"/>
        </VBox>

        <!-- Spacer pushes button to bottom -->
        <Region VBox.vgrow="ALWAYS"/>

        <!-- Footer: Warning + Next/Submit button -->
        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Label fx:id="warningLabel" text="Please select an answer!"
                   styleClass="error-label"
                   visible="false" managed="false"/>
            <Button fx:id='prevBtn' text = "Previous"
                    onAction = '#handlePrevious'
                    styleClass = 'secondary-btn'
                    prefWidth = '160'
                    prefHeight = '42' />
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="nextBtn" text="Next"
                    onAction="#handleNext"
                    styleClass="primary-btn"
                    prefWidth="160" prefHeight="42"/>
        </HBox>
    </VBox>
</StackPane>
