<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.canvas.Canvas?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="quiz.controller.ResultController"
           styleClass="root-pane"
           prefWidth="900" prefHeight="650">

    <!-- Main result card -->
    <VBox alignment="CENTER" spacing="18"
          styleClass="card" maxWidth="500" maxHeight="560">
        <padding>
            <Insets top="45" right="50" bottom="45" left="50"/>
        </padding>

        <Label text="Quiz Complete!" styleClass="title-label"/>
        <Label fx:id="playerLabel" text="" styleClass="subtitle-label"/>
        <Label fx:id="scoreLabel" text="" styleClass="score-label"/>
        <Label fx:id="percentLabel" text="" styleClass="percent-label"
               prefWidth="500" alignment="CENTER"/>
        <Label fx:id="gradeLabel" text="" styleClass="grade-label"
               prefWidth="300" alignment="CENTER"/>
        <Label fx:id="feedbackLabel" text=""
               styleClass="feedback-label"
               wrapText="true" textAlignment="CENTER" alignment="CENTER"
               maxWidth="400"/>

        <Button text="Play Again"
                onAction="#handleRestart"
                styleClass="primary-btn"
                prefWidth="320" prefHeight="45"/>
        <Button text="View Detailed Analysis"
                onAction="#handleAnalysis"
                styleClass="primary-btn"
                prefWidth="320" prefHeight="45"/>
        <Button text="View Stats"
                onAction="#handleStats"
                styleClass="primary-btn"
                prefWidth="320" prefHeight="45"/>
    </VBox>

    <!-- Stats popup overlay (hidden by default) -->
    <StackPane fx:id="popupOverlay"
               visible="false"
               style="-fx-background-color: rgba(0,0,0,0.6);">

        <VBox alignment="TOP_CENTER" spacing="16"
              maxWidth="620" maxHeight="500"
              style="-fx-background-color: rgba(255,255,255,0.07);
                     -fx-background-radius: 24;
                     -fx-border-color: rgba(255,255,255,0.12);
                     -fx-border-radius: 24;
                     -fx-border-width: 1;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.5),30,0,0,10);">
            <padding>
                <Insets top="30" right="36" bottom="30" left="36"/>
            </padding>

            <!-- Popup header -->
            <HBox alignment="CENTER_LEFT" spacing="16">
                <Label text="Quiz Statistics"
                       styleClass="title-label"
                       style="-fx-font-size: 24;"
                       HBox.hgrow="ALWAYS"/>
                <Button text="X"
                        onAction="#handleCloseStats"
                        style="-fx-background-color: rgba(255,255,255,0.1);
                               -fx-text-fill: white;
                               -fx-font-size: 14;
                               -fx-font-weight: bold;
                               -fx-background-radius: 50;
                               -fx-min-width: 32;
                               -fx-min-height: 32;
                               -fx-cursor: hand;"/>
            </HBox>

            <!-- Canvas for bar chart -->
            <Canvas fx:id="chartCanvas" width="548" height="340"/>

        </VBox>
    </StackPane>

</StackPane>