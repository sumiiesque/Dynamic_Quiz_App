<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!-- Result Screen: Score + Grade + Feedback + Restart -->
<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="quiz.controller.ResultController"
           styleClass="root-pane"
           prefWidth="900" prefHeight="650">

    <VBox alignment="CENTER" spacing="18"
          styleClass="card" maxWidth="500" maxHeight="520">

        <padding>
            <Insets top="45" right="50" bottom="45" left="50"/>
        </padding>

        <!-- Title -->
        <Label text="Quiz Complete!" styleClass="title-label"/>

        <!-- Player greeting -->
        <Label fx:id="playerLabel" text="" styleClass="subtitle-label"/>

        <!-- Score (e.g. "7 / 10") -->
        <Label fx:id="scoreLabel" text="" styleClass="score-label"/>

        <!-- Percentage -->
        <Label fx:id="percentLabel" text="" styleClass="percent-label"/>

        <!-- Letter grade badge -->
        <Label fx:id="gradeLabel" text="" styleClass="grade-label"/>

        <!-- Feedback message -->
        <Label fx:id="feedbackLabel" text=""
               styleClass="feedback-label"
               wrapText="true" textAlignment="CENTER"
               maxWidth="400"/>

        <!-- Play Again button -->
        <Button text="Play Again"
                onAction="#handleRestart"
                styleClass="primary-btn"
                prefWidth="200" prefHeight="45"/>
    </VBox>
</StackPane>
