<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!-- Start Screen: Title + Name Input + Start Button -->
<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="quiz.controller.StartController"
           styleClass="root-pane"
           prefWidth="900" prefHeight="650">

    <VBox alignment="CENTER" spacing="25"
          styleClass="card" maxWidth="460" maxHeight="480">

        <padding>
            <Insets top="50" right="50" bottom="50" left="50"/>
        </padding>

        <!-- Title -->
        <Label text="Quiz Master" styleClass="title-label"/>
        <Label text="Test Your Java Knowledge" styleClass="subtitle-label"/>

        <!-- Name input group -->
        <VBox spacing="8">
            <Label text="Your Name" styleClass="field-label"/>
            <TextField fx:id="nameField"
                       promptText="Enter your name..."
                       styleClass="text-input"/>
        </VBox>

        <!-- Validation error (hidden by default) -->
        <Label fx:id="errorLabel"
               styleClass="error-label"
               visible="false" managed="false"/>

        <!-- Start button -->
        <Button text="Start Quiz"
                onAction="#handleStart"
                styleClass="primary-btn"
                prefWidth="200" prefHeight="45"/>

        <Label fx:id="loadingLabel"
       text="Loading questions..."
       visible="false"
       managed="false"
       style="-fx-text-fill: white; -fx-font-size: 16px;"/>
    </VBox>
</StackPane>
